{
  "name": "sk-finanzberatung",
  "type": "module",
  "version": "1.0.0",
  "description": "Unternehmenswebsite fuer SK-Finanzberatung - unabhaengige Honorar-Finanzberatung (Simon Kuper). Abhaengigkeitsfreier statischer Generator (nur Node-Bordmittel).",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs && node scripts/serve.mjs",
    "serve": "node scripts/serve.mjs",
    "test": "node --test tests/*.test.mjs",
    "images": "node scripts/optimize-images.mjs",
    "download-images": "node scripts/download-images.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\""
  }
}
